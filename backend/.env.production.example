# ========================================
# 后端生产环境配置示例
# ========================================
# 部署时复制此文件为 .env 并修改以下配置

# ----------------------------------------
# Flask 应用配置
# ----------------------------------------
# 生产环境必须关闭DEBUG模式
DEBUG=False
FLASK_ENV=production

# 服务端口（默认5000）
PORT=5000

# 密钥（重要！必须修改）
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=请修改为随机生成的密钥至少32位

# ----------------------------------------
# CORS 配置（重要！）
# ----------------------------------------
# 允许的前端域名（用逗号分隔）
# 部署后修改为你的实际域名
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ----------------------------------------
# DeepSeek AI API 配置
# ----------------------------------------
# DeepSeek API密钥（必需）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=你的DeepSeek_API密钥

# DeepSeek API地址（通常不需要修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# AI模型配置
AI_MODEL_DEFAULT=deepseek-chat
AI_MODEL_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# ----------------------------------------
# JWT 认证配置
# ----------------------------------------
# JWT密钥（重要！必须修改）
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=请修改为随机生成的JWT密钥至少32位

# Token过期时间（秒）
JWT_ACCESS_TOKEN_EXPIRES=86400

# ----------------------------------------
# Stripe 支付配置（如果启用）
# ----------------------------------------
# Stripe密钥（生产环境使用live密钥）
STRIPE_SECRET_KEY=sk_live_你的Stripe密钥
STRIPE_PUBLISHABLE_KEY=pk_live_你的Stripe公钥
STRIPE_WEBHOOK_SECRET=whsec_你的Webhook密钥

# Stripe价格ID（月度会员）
STRIPE_PRICE_ID_MONTHLY=price_你的月度会员价格ID

# Stripe价格ID（年度会员）
STRIPE_PRICE_ID_YEARLY=price_你的年度会员价格ID

# ----------------------------------------
# 用户配额配置
# ----------------------------------------
# 免费用户每日解析次数
USER_QUOTA_FREE_DAILY=5

# 月度会员每日解析次数
USER_QUOTA_MONTHLY_DAILY=100

# 年度会员每日解析次数（-1表示无限）
USER_QUOTA_YEARLY_DAILY=-1

# ----------------------------------------
# 缓存配置
# ----------------------------------------
# 视频缓存大小限制（MB）
VIDEO_CACHE_MAX_SIZE_MB=20480

# 视频缓存TTL（秒）
VIDEO_CACHE_TTL=2592000

# ----------------------------------------
# 上传限制
# ----------------------------------------
# 最大上传大小（字节）
MAX_CONTENT_LENGTH=104857600

# ----------------------------------------
# 日志配置
# ----------------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=logs/app.log

# ----------------------------------------
# 安全配置
# ----------------------------------------
# 会话Cookie安全设置
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax